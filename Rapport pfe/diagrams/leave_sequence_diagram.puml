@startuml
autonumber
skinparam BoxPadding 10
skinparam ParticipantPadding 10
skinparam BackgroundColor #ffffff
skinparam RoundCorner 4

skinparam ActorBorderColor #b4975a
skinparam ActorBackgroundColor #fcfbf7
skinparam ParticipantBorderColor #b4975a
skinparam ParticipantBackgroundColor #fcfbf7
skinparam DatabaseBorderColor #b4975a
skinparam DatabaseBackgroundColor #fcfbf7
skinparam ArrowColor #b4975a

actor "Client (Company Manager)" as Client
box "Frontend (Flutter App)" #LightBlue
  participant "LeaveScreen" as LeaveUI
  participant "Supabase Client SDK" as SDK
end box

box "Backend (Supabase & PostgreSQL)" #LightGreen
  participant "PostgreSQL Database" as DB
end box

== Submit Leave Request ==
Client -> LeaveUI : Fill & submit leave form
activate LeaveUI

LeaveUI -> SDK : insert() leave request details
activate SDK

SDK -> DB : Insert row in 'conges' table
activate DB
note over DB : PostgreSQL RLS verifies company_id matching user session
DB --> SDK : Row created successfully
deactivate DB

SDK --> LeaveUI : Return success status
deactivate SDK

LeaveUI --> Client : Render success status
deactivate LeaveUI

@enduml
