@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Client (Company Manager)" as client

rectangle "HMI Stars Mobile Client App" {
  usecase "Authenticate / Reset Password" as UC_Auth
  usecase "Manage Account Profile & Settings" as UC_Settings
  
  package "Personnel & Work Activities" {
    usecase "Manage Employees (Add, View, Edit, Delete, Archive/Unarchive)" as UC_Manage_Employees
    usecase "Log Daily Attendance (Pointages)" as UC_Pointage
    usecase "Submit a Leave Request" as UC_Conge
    usecase "Process Employee Leave Requests" as UC_Process_Conge
    usecase "Issue Employee Warnings" as UC_Issue_Warnings
  }
  
  package "Documents & Chat Workspace" {
    usecase "Upload Accounting & Administrative Documents" as UC_Upload_Docs_Client
    usecase "Send Notices/Warnings to HMI Stars Manager" as UC_Client_Send_Notices
    usecase "Chat in Real-Time with the Firm" as UC_Chat
  }
}

client --> UC_Auth
client --> UC_Settings
client --> UC_Manage_Employees
client --> UC_Pointage
client --> UC_Conge
client --> UC_Process_Conge
client --> UC_Issue_Warnings
client --> UC_Upload_Docs_Client
client --> UC_Client_Send_Notices
client --> UC_Chat

UC_Settings ..> UC_Auth : <<include>>
UC_Manage_Employees ..> UC_Auth : <<include>>
UC_Pointage ..> UC_Auth : <<include>>
UC_Conge ..> UC_Auth : <<include>>
UC_Process_Conge ..> UC_Auth : <<include>>
UC_Issue_Warnings ..> UC_Auth : <<include>>
UC_Upload_Docs_Client ..> UC_Auth : <<include>>
UC_Client_Send_Notices ..> UC_Auth : <<include>>
UC_Chat ..> UC_Auth : <<include>>

@enduml
