@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Manager (HMI Stars)" as admin

rectangle "HMI Stars Web Admin Platform" {
  usecase "Authenticate / Reset Password" as UC_Auth
  usecase "Manage Account Profile & Settings" as UC_Settings
  
  package "Client & Company Management" {
    usecase "Manage Companies (Create, Categorize, Archive/Unarchive, Delete)" as UC_Manage_Companies
    usecase "Manage Company Employees & Data (Create, Delete, Edit, Export)" as UC_Manage_Company_Employees
    usecase "Manage HMI Stars Users & Roles (Secretaries, Admins)" as UC_Manage_Users
  }
  
  package "Operations & Communication" {
    usecase "Send & Receive Client Documents" as UC_Manage_Docs_Firm
    usecase "Schedule Tasks & Reminders for Clients" as UC_Firm_Taches
    usecase "Chat in Real-Time with Clients" as UC_Chat
    usecase "Review Notices/Warnings Sent by Clients" as UC_Review_Notices
  }
}

admin --> UC_Auth
admin --> UC_Settings
admin --> UC_Manage_Companies
admin --> UC_Manage_Company_Employees
admin --> UC_Manage_Users
admin --> UC_Manage_Docs_Firm
admin --> UC_Firm_Taches
admin --> UC_Chat
admin --> UC_Review_Notices

UC_Settings ..> UC_Auth : <<include>>
UC_Manage_Companies ..> UC_Auth : <<include>>
UC_Manage_Company_Employees ..> UC_Auth : <<include>>
UC_Manage_Users ..> UC_Auth : <<include>>
UC_Manage_Docs_Firm ..> UC_Auth : <<include>>
UC_Firm_Taches ..> UC_Auth : <<include>>
UC_Chat ..> UC_Auth : <<include>>
UC_Review_Notices ..> UC_Auth : <<include>>

@enduml
