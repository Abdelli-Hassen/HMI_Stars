# Root .gitignore for HMI Stars Monorepo

# IDE and System files
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# Flutter/Dart common ignores (if any leak to root)
.dart_tool/
.packages
.pub-cache/
.pub/
build/

# Mobile specific (general patterns)
*.log
*.mode1v3
*.mode2v3
*.moved-aside
*.pbxuser
*.perspectivev3
*.xccheckout
*.xcscmblueprint
*.xcuserstate

# --- HMI Stars Security Patches ---
# Google & Firebase service account private keys
*-firebase-adminsdk-*.json
*.service-account.json

# Local configurations with sensitive credentials (serviceRoleKey, anonKey)
supabase_config.dart
**/supabase_config.dart

# Gradle caches & build logs
.gradle/
**/.gradle/

# Android local properties containing machine-specific SDK paths
local.properties
**/local.properties

# Signing keys & Keystores
*.keystore
*.jks

# Compilation/Build products
*.apk
*.ap_
*.aab
*.dex
*.class

# iOS/macOS build outputs and ephemeral configs
ephemeral/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/macos/Flutter/ephemeral/