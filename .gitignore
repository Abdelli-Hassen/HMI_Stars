# Root .gitignore for HMI Stars Monorepo

# Folders to exclude as requested
.agent/
diary/
Optimizing Real-Time Messaging Architecture.md
# IDE and System files
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# Flutter/Dart common ignores (if any leak to root)
.dart_tool/
.packages
.pub-cache/
.pub/
build/

# Mobile specific (general patterns)
*.log
*.mode1v3
*.mode2v3
*.moved-aside
*.pbxuser
*.perspectivev3
*.xccheckout
*.xcscmblueprint
*.xcuserstate

# Secret files (CRITICAL)
.env
.env.*
! .env.example
*.key
*.pem
*.jks
*.p12
*.keystore
google-services.json
GoogleService-Info.plist
supabase_config.dart

# Extra scratch files and images
flutter_01.png
fix_consts.dart
fix_consts2.dart
replace_colors.dart
*.sql
